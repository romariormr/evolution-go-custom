# ============================================================================
# Evolution GO Custom — standalone environment
# ----------------------------------------------------------------------------
# install.sh generates a real ./deploy/.env from this template, filling
# GLOBAL_API_KEY and POSTGRES_PASSWORD with strong random values.
# If you configure manually: copy this file to .env and replace every
# "CHANGE_ME" below with your own strong, unique secret.
# ============================================================================

# ---- Server ----------------------------------------------------------------
SERVER_PORT=8080
CLIENT_NAME=evolution
OS_NAME=Linux

# ---- Security (REQUIRED) ---------------------------------------------------
# Master API key. Send it as the "apikey" header on every request.
GLOBAL_API_KEY=CHANGE_ME_STRONG_API_KEY

# ---- Database (Postgres runs inside the compose network) -------------------
# POSTGRES_USER / POSTGRES_PASSWORD are used by BOTH the postgres service and
# the two DSNs below. Keep them in sync.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_AUTH_DB=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/evogo_auth?sslmode=disable
POSTGRES_USERS_DB=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/evogo_users?sslmode=disable
DATABASE_SAVE_MESSAGES=false

# ---- Logs ------------------------------------------------------------------
WADEBUG=INFO
LOGTYPE=console
LOG_DIRECTORY=/app/logs
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE=30
LOG_COMPRESS=true

# ---- Connection ------------------------------------------------------------
CONNECT_ON_STARTUP=false
WEBHOOK_FILES=true

# ---- Events (optional) -----------------------------------------------------
WEBHOOK_URL=
AMQP_URL=
AMQP_GLOBAL_ENABLED=false
NATS_URL=
NATS_GLOBAL_ENABLED=false
EVENT_IGNORE_GROUP=false
EVENT_IGNORE_STATUS=true

# ---- Media storage (MinIO/S3) — disabled by default ------------------------
MINIO_ENABLED=false

# ---- Proxy (optional) ------------------------------------------------------
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ---- Misc ------------------------------------------------------------------
QRCODE_MAX_COUNT=5
CHECK_USER_EXISTS=true
